<Window x:Class="OPCGatewayTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OPC DA to OPC UA Gateway" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- 轉換器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- 樣式 -->
        <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="5,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="True">
                    <Setter Property="Fill" Value="Green"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding}" Value="False">
                    <Setter Property="Fill" Value="Red"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具欄 -->
        <ToolBar Grid.Row="0" Height="35">
            <Button Content="連接 OPC DA" Command="{Binding ConnectOPCDACommand}" Width="100" Margin="2"/>
            <Button Content="斷開 OPC DA" Command="{Binding DisconnectOPCDACommand}" Width="100" Margin="2"/>
            <Separator/>
            <Button Content="啟動 OPC UA" Command="{Binding StartOPCUACommand}" Width="100" Margin="2"/>
            <Button Content="停止 OPC UA" Command="{Binding StopOPCUACommand}" Width="100" Margin="2"/>
            <Separator/>
            <Button Content="載入配置" Command="{Binding LoadConfigCommand}" Width="80" Margin="2"/>
            <Button Content="保存配置" Command="{Binding SaveConfigCommand}" Width="80" Margin="2"/>
            <Separator/>
            <Button Content="清除日誌" Command="{Binding ClearLogCommand}" Width="80" Margin="2"/>
        </ToolBar>

        <!-- 主要內容區域 -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左欄：OPC DA 配置和項目瀏覽 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <!-- OPC DA 配置 -->
                <GroupBox Header="OPC DA 配置" Grid.Row="0" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="伺服器名:" VerticalAlignment="Center" Margin="0,2"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                      ItemsSource="{Binding AvailableOPCDAServers}"
                                      SelectedItem="{Binding OPCDAConfig.ServerName}"
                                      Text="{Binding OPCDAConfig.ServerName, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True" Margin="2"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="掃描" 
                                    Command="{Binding ScanOPCDAServersCommand}" Width="60" Margin="2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="主機名:" VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OPCDAConfig.HostName}" Margin="2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="更新頻率:" VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OPCDAConfig.UpdateRate}" Margin="2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="ms" VerticalAlignment="Center" Margin="2"/>

                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,5">
                                <Ellipse Style="{StaticResource StatusIndicatorStyle}" DataContext="{Binding IsOPCDAConnected}"/>
                                <TextBlock Text="{Binding OPCDAConnectionStatus}" Style="{StaticResource StatusTextStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"/>

                <!-- OPC DA 項目瀏覽 -->
                <GroupBox Header="OPC DA 項目瀏覽" Grid.Row="2" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 操作按鈕 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <Button Content="瀏覽項目" Command="{Binding BrowseOPCDAItemsCommand}" Width="80" Margin="2"/>
                            <Button Content="添加選中" Command="{Binding AddSelectedItemsCommand}" Width="80" Margin="2"/>
                        </StackPanel>

                        <!-- 搜尋功能 -->
                        <Grid Grid.Row="1" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="SearchTextBox" 
                                     Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" 
                                     ToolTip="輸入搜尋關鍵字..." Margin="2"/>
                            <Button Grid.Column="1" Content="搜尋" 
                                    Command="{Binding SearchItemsCommand}" Width="60" Margin="2"/>
                            <Button Grid.Column="2" Content="清除" 
                                    Command="{Binding ClearSearchCommand}" Width="60" Margin="2"/>
                        </Grid>

                        <!-- 樹狀項目瀏覽 -->
                        <TreeView Grid.Row="2" ItemsSource="{Binding OPCTreeNodes}" Margin="2" x:Name="OPCTreeView">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="2" 
                                                  Visibility="{Binding IsItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="📁" Margin="2" 
                                                   Visibility="{Binding IsFolder, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="📄" Margin="2" 
                                                   Visibility="{Binding IsItem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding Name}" Margin="2" ToolTip="{Binding FullPath}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </Grid>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"/>

            <!-- 中欄：數據映射和即時數據 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 數據映射區域 -->
                <GroupBox Header="數據映射" Grid.Row="0" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <CheckBox Content="啟用映射" IsChecked="{Binding IsMappingEnabled}" Margin="2"/>
                            <Button Content="清除映射" Command="{Binding ClearMappingsCommand}" Width="80" Margin="2"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding ItemMappings}" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" Margin="2">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="啟用" Binding="{Binding IsEnabled}" Width="50"/>
                                <DataGridTextColumn Header="OPC DA 項目" Binding="{Binding OPCDAItemId}" Width="*"/>
                                <DataGridTextColumn Header="OPC UA 節點" Binding="{Binding OPCUABrowseName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"/>

                <!-- 即時數據顯示 -->
                <GroupBox Header="即時數據" Grid.Row="2" Style="{StaticResource GroupBoxStyle}">
                    <DataGrid ItemsSource="{Binding RealTimeData}" AutoGenerateColumns="False" 
                              IsReadOnly="True" Margin="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="項目ID" Binding="{Binding ItemId}" Width="*"/>
                            <DataGridTextColumn Header="值" Binding="{Binding ValueString}" Width="100"/>
                            <DataGridTextColumn Header="品質" Binding="{Binding QualityString}" Width="80"/>
                            <DataGridTextColumn Header="時間戳" Binding="{Binding TimestampString}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch"/>

            <!-- 右欄：OPC UA 配置和客戶端狀態 -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- OPC UA 配置 -->
                <GroupBox Header="OPC UA 配置" Grid.Row="0" Style="{StaticResource GroupBoxStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="伺服器名:" VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OPCUAConfig.ServerName}" Margin="2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="端口:" VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OPCUAConfig.Port}" Margin="2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="應用名稱:" VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OPCUAConfig.ApplicationName}" Margin="2"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="最大客戶端:" VerticalAlignment="Center" Margin="0,2"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding OPCUAConfig.MaxClients}" Margin="2"/>

                            <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                                      Content="啟用安全" IsChecked="{Binding OPCUAConfig.EnableSecurity}" Margin="2"/>

                            <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,5">
                                <Ellipse Style="{StaticResource StatusIndicatorStyle}" DataContext="{Binding IsOPCUARunning}"/>
                                <TextBlock Text="{Binding OPCUAServerStatus}" Style="{StaticResource StatusTextStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- OPC UA 客戶端狀態 -->
                <GroupBox Header="客戶端狀態" Grid.Row="1" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="連接數:" Margin="2"/>
                            <TextBlock Text="{Binding ConnectedClientCount}" FontWeight="Bold" Margin="2"/>
                            <TextBlock Text="端點URL:" Margin="10,2,2,2"/>
                            <TextBlock Text="{Binding OPCUAEndpointUrl}" FontStyle="Italic" Margin="2"/>
                        </StackPanel>

                        <ListBox Grid.Row="1" ItemsSource="{Binding ConnectedClients}" Margin="2">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ClientName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding EndpointUrl}" FontSize="10" Foreground="Gray"/>
                                        <TextBlock Text="{Binding ConnectedTime, StringFormat='連接時間: {0:yyyy-MM-dd HH:mm:ss}'}" 
                                                   FontSize="10" Foreground="Gray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- 日誌區域 -->
        <GroupBox Header="系統日誌" Grid.Row="2" Style="{StaticResource GroupBoxStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox Text="{Binding LogMessages}" IsReadOnly="True" 
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </GroupBox>

        <!-- 狀態欄 -->
        <StatusBar Grid.Row="3" Height="25">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="OPC DA:"/>
                    <Ellipse Style="{StaticResource StatusIndicatorStyle}" DataContext="{Binding IsOPCDAConnected}"/>
                    <TextBlock Text="{Binding OPCDAItemCount, StringFormat='項目數: {0}'}" Margin="10,0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="OPC UA:"/>
                    <Ellipse Style="{StaticResource StatusIndicatorStyle}" DataContext="{Binding IsOPCUARunning}"/>
                    <TextBlock Text="{Binding OPCUANodeCount, StringFormat='節點數: {0}'}" Margin="10,0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveMappingCount, StringFormat='映射數: {0}'}" />
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalContentAlignment="Right">
                <TextBlock Text="{Binding CurrentTime, StringFormat='時間: {0:yyyy-MM-dd HH:mm:ss}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>